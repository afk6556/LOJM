<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Monopoly DUEL | Торги + Улучшения улиц</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            user-select: none;
        }

        body {
            font-family: 'Poppins', 'Segoe UI', system-ui, sans-serif;
            background: radial-gradient(circle at 10% 30%, #0a0f1e, #03060c);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 24px;
        }

        .game-neon {
            max-width: 1400px;
            width: 100%;
            background: rgba(15, 25, 45, 0.65);
            backdrop-filter: blur(10px);
            border-radius: 64px;
            border: 1px solid rgba(0, 255, 255, 0.4);
            box-shadow: 0 20px 40px rgba(0,0,0,0.6), 0 0 0 2px rgba(0,255,255,0.2), inset 0 1px 0 rgba(255,255,255,0.1);
            padding: 24px;
            transition: all 0.3s;
        }

        .players-duel {
            display: flex;
            gap: 28px;
            margin-bottom: 32px;
            flex-wrap: wrap;
        }

        .player-neon {
            flex: 1;
            background: linear-gradient(135deg, rgba(20,30,55,0.9), rgba(10,15,35,0.9));
            border-radius: 48px;
            padding: 20px 28px;
            border: 1px solid;
            transition: all 0.2s ease;
            box-shadow: 0 8px 20px rgba(0,0,0,0.4);
            backdrop-filter: blur(4px);
        }

        .player-neon.active-glow {
            border-color: #0ff;
            box-shadow: 0 0 20px #0ff, inset 0 0 5px rgba(0,255,255,0.5);
            background: linear-gradient(135deg, rgba(30,45,80,0.95), rgba(15,25,55,0.95));
            transform: scale(1.01);
        }

        .player-header {
            display: flex;
            align-items: center;
            gap: 14px;
            font-size: 1.8rem;
            font-weight: bold;
            color: #f0f3ff;
            text-shadow: 0 0 3px cyan;
        }

        .player-icon {
            background: #1e2a3a;
            padding: 8px 18px;
            border-radius: 60px;
            font-size: 1.3rem;
        }

        .money-neon {
            font-size: 2rem;
            font-weight: 800;
            margin: 12px 0 8px;
            background: linear-gradient(135deg, #F6E05E, #FFD966);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            text-shadow: 0 0 5px rgba(255,200,0,0.5);
        }

        .props-list {
            font-size: 0.7rem;
            max-height: 70px;
            overflow-y: auto;
            background: rgba(0,0,0,0.5);
            border-radius: 30px;
            padding: 6px 12px;
            color: #b9f6ff;
            cursor: pointer;
        }
        .props-list:hover {
            background: rgba(0,255,255,0.2);
        }

        .board-neon {
            background: rgba(0, 10, 20, 0.6);
            border-radius: 48px;
            padding: 20px;
            margin: 20px 0;
            border: 1px solid cyan;
        }

        .cells-neon-grid {
            display: grid;
            grid-template-columns: repeat(6, 1fr);
            gap: 12px;
        }

        .cell-neon {
            background: radial-gradient(ellipse at top, #19273c, #0c1322);
            border-radius: 24px;
            padding: 12px 4px;
            text-align: center;
            backdrop-filter: blur(4px);
            border: 1px solid rgba(0, 255, 255, 0.3);
            transition: 0.1s linear;
            box-shadow: 0 5px 10px rgba(0,0,0,0.3);
            min-height: 110px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            position: relative;
        }

        .cell-name-neon {
            font-weight: 800;
            background: #00adb5;
            display: inline-block;
            padding: 4px 8px;
            border-radius: 40px;
            font-size: 0.7rem;
            color: #071013;
            letter-spacing: 0.5px;
        }

        .cell-price-neon {
            font-size: 0.65rem;
            color: #f6c445;
        }

        .owner-neon {
            font-size: 0.6rem;
            background: #2f4858;
            border-radius: 20px;
            padding: 2px;
            margin-top: 4px;
            color: #b0e0ff;
        }
        .improvements {
            font-size: 0.55rem;
            background: #000000aa;
            border-radius: 16px;
            margin: 2px auto;
            width: fit-content;
            padding: 2px 6px;
        }
        .pawns-on-cell {
            display: flex;
            justify-content: center;
            gap: 8px;
            margin-top: 6px;
        }

        .pawn-piece {
            width: 26px;
            height: 26px;
            border-radius: 30px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            font-size: 14px;
            box-shadow: 0 0 5px cyan;
            transition: 0.1s;
        }

        .pawn-p1 { background: #ff4d6d; color: white; border: 1px solid #ffb3c6; box-shadow:0 0 6px #ff4d6d;}
        .pawn-p2 { background: #4d9de0; color: white; border: 1px solid #a3d0ff; box-shadow:0 0 6px #4d9de0;}

        .controls-neon {
            display: flex;
            gap: 18px;
            justify-content: center;
            flex-wrap: wrap;
            background: rgba(0,0,0,0.5);
            border-radius: 100px;
            padding: 18px 24px;
            margin-top: 10px;
        }

        .btn-neon {
            background: linear-gradient(135deg, #1f2b3c, #121b2a);
            border: none;
            color: #0ff;
            font-weight: bold;
            font-size: 1.2rem;
            padding: 12px 28px;
            border-radius: 60px;
            cursor: pointer;
            transition: all 0.15s;
            box-shadow: 0 4px 0 #001122;
            font-family: inherit;
        }

        .btn-neon:active {
            transform: translateY(2px);
            box-shadow: 0 1px 0 #001122;
        }

        .dice-area-neon {
            background: #000000aa;
            backdrop-filter: blur(8px);
            padding: 10px 30px;
            border-radius: 80px;
            display: inline-flex;
            gap: 25px;
            align-items: center;
            font-size: 2.6rem;
            font-weight: bold;
            letter-spacing: 8px;
        }

        .dice {
            text-shadow: 0 0 8px cyan;
            transition: transform 0.2s ease;
            display: inline-block;
        }

        .roll-anim {
            animation: diceShake 0.3s cubic-bezier(0.36, 0.07, 0.19, 0.97) both;
        }

        @keyframes diceShake {
            0% { transform: translate(0,0) rotate(0deg);}
            25% { transform: translate(8px, -6px) rotate(15deg);}
            50% { transform: translate(-6px, 8px) rotate(-10deg);}
            75% { transform: translate(4px, -4px) rotate(5deg);}
            100% { transform: translate(0,0) rotate(0deg);}
        }

        .msg-neon {
            background: #0a1122dd;
            border-radius: 48px;
            padding: 14px 20px;
            margin-top: 20px;
            text-align: center;
            color: #aaf0ff;
            font-weight: bold;
            border-left: 6px solid cyan;
        }

        .modal {
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            background: rgba(0,0,0,0.85);
            backdrop-filter: blur(12px);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 1000;
        }
        .modal-card {
            background: #111c2f;
            border-radius: 48px;
            padding: 30px;
            max-width: 500px;
            width: 90%;
            text-align: center;
            border: 2px solid cyan;
            box-shadow: 0 0 30px cyan;
        }
        .bid-input {
            font-size: 1.5rem;
            padding: 10px;
            border-radius: 60px;
            text-align: center;
            width: 160px;
            background: #010a15;
            color: #f0f0f0;
            border: 1px solid cyan;
            margin: 15px;
        }
        .modal-buttons {
            display: flex;
            gap: 20px;
            justify-content: center;
            margin-top: 20px;
        }
        .property-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: #0a1a2a;
            margin: 8px 0;
            padding: 8px;
            border-radius: 30px;
        }
        .hide {
            display: none;
        }
        button:disabled {
            opacity: 0.5;
            transform: none;
        }
        @media (max-width: 780px) {
            .cells-neon-grid { gap: 6px; }
            .cell-neon { min-height: 85px; }
            .btn-neon { padding: 8px 16px; font-size: 0.9rem; }
        }
    </style>
</head>
<body>
<div class="game-neon" id="gameRoot">
    <div class="players-duel">
        <div class="player-neon" id="p1card">
            <div class="player-header"><span class="player-icon">🔴 R1</span> Игрок 1 (Красный)</div>
            <div class="money-neon" id="money1">💰 1500</div>
            <div class="props-list" id="props1">📦 нет</div>
        </div>
        <div class="player-neon" id="p2card">
            <div class="player-header"><span class="player-icon">🔵 B2</span> Игрок 2 (Синий)</div>
            <div class="money-neon" id="money2">💰 1500</div>
            <div class="props-list" id="props2">📦 нет</div>
        </div>
    </div>

    <div class="board-neon">
        <div class="cells-neon-grid" id="boardGrid"></div>
    </div>

    <div class="controls-neon">
        <div class="dice-area-neon">
            <span class="dice" id="dice1">⚀</span> + <span class="dice" id="dice2">⚀</span>
        </div>
        <button class="btn-neon" id="rollBtn">🎲 БРОСИТЬ</button>
        <button class="btn-neon" id="endTurnBtn">➡️ ЗАВЕРШИТЬ</button>
        <button class="btn-neon" id="tradeBtn">🤝 ТОРГИ</button>
        <button class="btn-neon" id="upgradeBtn">🏗️ УЛУЧШИТЬ</button>
        <button class="btn-neon" id="resetBtn">🔄 НОВАЯ ИГРА</button>
    </div>
    <div class="msg-neon" id="msgBox">⚡ Игра началась! Ход Игрока 1. Бросай кубики.</div>
</div>

<script>
    // ------------------------- КАРТА ПОЛЯ (20 клеток) + данные аренды с улучшениями -------------------------
    const RENT_PROGRESSION = {
        "brown": [4, 20, 60, 180, 500, 700],
        "lightblue": [6, 30, 90, 270, 800, 1000],
        "pink": [10, 50, 150, 450, 1200, 1500],
        "orange": [14, 70, 200, 550, 1500, 1800]
    };
    const BOARD_DATA = [
        { id:0, name:"СТАРТ", type:"start", price:0, rent:0, color:"#ffd966" },
        { id:1, name:"Медитерраней", type:"property", price:60, rentBase:4, color:"#bc9a6c", group:"brown", houseCost:50, improvements:0 },
        { id:2, name:"ОБЩ. КАЗНА", type:"chest", price:0 },
        { id:3, name:"Балтик авеню", type:"property", price:60, rentBase:4, color:"#bc9a6c", group:"brown", houseCost:50, improvements:0 },
        { id:4, name:"НАЛОГ $200", type:"tax", price:0, rent:200 },
        { id:5, name:"Чикаго ж/д", type:"railroad", price:200, rent:25, group:"rail" },
        { id:6, name:"Ориентал ав.", type:"property", price:100, rentBase:6, color:"#5dade2", group:"lightblue", houseCost:50, improvements:0 },
        { id:7, name:"ШАНС", type:"chance", price:0 },
        { id:8, name:"Вермонт ав.", type:"property", price:100, rentBase:6, color:"#5dade2", group:"lightblue", houseCost:50, improvements:0 },
        { id:9, name:"Коннектикут", type:"property", price:120, rentBase:8, color:"#5dade2", group:"lightblue", houseCost:50, improvements:0 },
        { id:10, name:"ТЮРЬМА", type:"jail", price:0 },
        { id:11, name:"Сент-Чарльз", type:"property", price:140, rentBase:10, color:"#f5b7b1", group:"pink", houseCost:100, improvements:0 },
        { id:12, name:"ЭЛЕКТРОКОМП.", type:"utility", price:150, rentMulti:4, group:"util" },
        { id:13, name:"Стейтс ав.", type:"property", price:140, rentBase:10, color:"#f5b7b1", group:"pink", houseCost:100, improvements:0 },
        { id:14, name:"Вирджиния ав.", type:"property", price:160, rentBase:12, color:"#f5b7b1", group:"pink", houseCost:100, improvements:0 },
        { id:15, name:"Пенсильвания ж/д", type:"railroad", price:200, rent:25, group:"rail" },
        { id:16, name:"Сент-Джеймс", type:"property", price:180, rentBase:14, color:"#f9e79f", group:"orange", houseCost:100, improvements:0 },
        { id:17, name:"ОБЩ. КАЗНА", type:"chest", price:0 },
        { id:18, name:"Теннесси ав.", type:"property", price:180, rentBase:14, color:"#f9e79f", group:"orange", houseCost:100, improvements:0 },
        { id:19, name:"НЬЮ-ЙОРК ав.", type:"property", price:200, rentBase:16, color:"#f9e79f", group:"orange", houseCost:100, improvements:0 }
    ];

    let players = [
        { id:0, name:"Игрок 1", money:1500, pos:0, inJail:false, jailTurns:0, properties:[], icon:"🔴" },
        { id:1, name:"Игрок 2", money:1500, pos:0, inJail:false, jailTurns:0, properties:[], icon:"🔵" }
    ];
    let cellOwner = new Array(BOARD_DATA.length).fill(-1);
    let currentPlayer = 0;
    let gameActive = true;
    let justRolled = false;
    let doublesCount = 0;
    let dice1Val = 1, dice2Val = 1, diceSum = 2;
    let waitingAuction = false;

    // ---------- Вспомогательные функции ----------
    function getRent(cell, playerIdx) {
        let owner = cellOwner[cell.id];
        if (owner === -1 || owner === playerIdx) return 0;
        if (cell.type === "property") {
            let level = cell.improvements || 0;
            let progression = RENT_PROGRESSION[cell.group];
            if(progression && level <= 5) return progression[level];
            return cell.rentBase;
        }
        if(cell.type === "railroad"){
            let ownedRail = BOARD_DATA.filter(c => c.type==="railroad" && cellOwner[c.id]===owner).length;
            return {1:25,2:50,3:100,4:200}[ownedRail] || 25;
        }
        if(cell.type === "utility"){
            let utils = BOARD_DATA.filter(c => c.type==="utility" && cellOwner[c.id]===owner).length;
            let mult = utils===2 ? 10 : 4;
            return mult * diceSum;
        }
        return 0;
    }

    // проверка монополии (все улицы группы принадлежат одному игроку)
    function hasMonopoly(playerId, group){
        let groupCells = BOARD_DATA.filter(c => c.type === "property" && c.group === group);
        if(groupCells.length === 0) return false;
        return groupCells.every(c => cellOwner[c.id] === playerId);
    }

    function updateUI() {
        for(let i=0;i<2;i++){
            document.getElementById(`money${i+1}`).innerHTML = `💰 ${players[i].money}`;
            let propsStr = players[i].properties.map(pid => {
                let cell = BOARD_DATA[pid];
                let level = cell.improvements || 0;
                let stars = level===0 ? "🏠0" : (level===5 ? "🏨" : "🏠".repeat(level));
                return `${cell.name.substring(0,8)} ${stars}`;
            }).join(", ");
            document.getElementById(`props${i+1}`).innerHTML = `📦 ${propsStr || "нет"}`;
        }
        const p1c = document.getElementById("p1card");
        const p2c = document.getElementById("p2card");
        if(currentPlayer===0) { p1c.classList.add("active-glow"); p2c.classList.remove("active-glow");}
        else { p2c.classList.add("active-glow"); p1c.classList.remove("active-glow");}
        // отрисовка поля
        const grid = document.getElementById("boardGrid");
        grid.innerHTML = "";
        BOARD_DATA.forEach((cell, idx) => {
            const div = document.createElement("div");
            div.className = "cell-neon";
            if(cell.type==="property") div.style.background = `radial-gradient(circle at 20% 30%, ${cell.color}55, #0a1222)`;
            let priceHtml = cell.price > 0 ? `<div class="cell-price-neon">💰${cell.price}</div>` : `<div style="font-size:0.6rem">✨</div>`;
            let ownerHtml = cellOwner[idx] !== -1 ? `<div class="owner-neon">👑 ${players[cellOwner[idx]].icon}</div>` : `<div class="owner-neon">🔓 свободно</div>`;
            let improvementsHtml = "";
            if(cell.type === "property" && cell.improvements > 0){
                let level = cell.improvements;
                let icon = level === 5 ? "🏨" : "🏠".repeat(level);
                improvementsHtml = `<div class="improvements">${icon} Lv${level}</div>`;
            }
            div.innerHTML = `
                <div class="cell-name-neon">${cell.name.substring(0,12)}</div>
                ${priceHtml}
                ${ownerHtml}
                ${improvementsHtml}
                <div class="pawns-on-cell" id="pawns-${idx}"></div>
            `;
            grid.appendChild(div);
        });
        for(let idx=0; idx<BOARD_DATA.length; idx++){
            const container = document.getElementById(`pawns-${idx}`);
            if(container){
                container.innerHTML = "";
                for(let p=0;p<players.length;p++){
                    if(players[p].pos === idx){
                        const pawnSpan = document.createElement("div");
                        pawnSpan.className = `pawn-piece pawn-p${p===0?"p1":"p2"}`;
                        pawnSpan.innerText = p===0?"1":"2";
                        container.appendChild(pawnSpan);
                    }
                }
            }
        }
        document.getElementById("dice1").innerHTML = getDiceSym(dice1Val);
        document.getElementById("dice2").innerHTML = getDiceSym(dice2Val);
    }

    function getDiceSym(v){ const s=["⚀","⚁","⚂","⚃","⚄","⚅"]; return s[v-1]; }
    function showMsg(msg, err=false){ 
        const box = document.getElementById("msgBox");
        box.innerHTML = err ? `⚠️ ${msg}` : `✨ ${msg}`;
        box.style.borderLeftColor = err ? "#ff5555" : "#0ff";
    }

    // ---------- УЛУЧШЕНИЯ ----------
    function openUpgradePanel(){
        if(!gameActive) return;
        let p = players[currentPlayer];
        let ownedProps = p.properties.filter(pid => BOARD_DATA[pid].type === "property");
        if(ownedProps.length === 0){
            showMsg("У вас нет ни одной улицы для улучшения!", true);
            return;
        }
        // группируем по группам, проверяем монополию
        let groupsAvailable = new Set();
        for(let pid of ownedProps){
            let cell = BOARD_DATA[pid];
            if(hasMonopoly(currentPlayer, cell.group)){
                groupsAvailable.add(cell.group);
            }
        }
        if(groupsAvailable.size === 0){
            showMsg("Нет полных цветовых групп (монополии), нельзя строить дома!", true);
            return;
        }
        // создаём модалку со всеми улицами, которые в монопольных группах
        let modal = document.createElement("div"); modal.className = "modal";
        let listHtml = `<div class="modal-card"><h3>🏗️ СТРОИТЕЛЬСТВО / ПРОДАЖА</h3>`;
        for(let pid of ownedProps){
            let cell = BOARD_DATA[pid];
            if(hasMonopoly(currentPlayer, cell.group)){
                let level = cell.improvements || 0;
                let cost = cell.houseCost;
                let nextCost = level < 5 ? (level===4 ? cost*2 : cost) : 0;
                let sellPrice = level > 0 ? (level===5 ? cost : Math.floor(cost/2)) : 0;
                listHtml += `
                    <div class="property-row">
                        <span><strong>${cell.name}</strong> (${cell.group}) [🏠${level}]</span>
                        <div>
                            ${level < 5 ? `<button class="btn-neon small upgrade-act" data-id="${pid}" data-type="up" style="font-size:0.8rem; padding:4px 12px;">➕ Купить (${nextCost}₽)</button>` : ''}
                            ${level > 0 ? `<button class="btn-neon small downgrade-act" data-id="${pid}" data-type="down" style="font-size:0.8rem; padding:4px 12px;">➖ Продать (+${sellPrice}₽)</button>` : ''}
                        </div>
                    </div>
                `;
            }
        }
        listHtml += `<div class="modal-buttons"><button id="closeUpgradeModal" class="btn-neon">ЗАКРЫТЬ</button></div></div>`;
        modal.innerHTML = listHtml;
        document.body.appendChild(modal);
        // обработчики
        modal.querySelectorAll(".upgrade-act").forEach(btn => {
            btn.onclick = () => {
                let propId = parseInt(btn.dataset.id);
                let cell = BOARD_DATA[propId];
                let level = cell.improvements || 0;
                let cost = (level===4 ? cell.houseCost*2 : cell.houseCost);
                if(players[currentPlayer].money >= cost && level < 5){
                    // проверим, что все улицы группы имеют одинаковый уровень в пределах 1 (по правилам: разница не более 1 дома)
                    let groupCells = BOARD_DATA.filter(c => c.type==="property" && c.group === cell.group);
                    let levels = groupCells.map(c => c.improvements || 0);
                    let canUpgrade = true;
                    if(level < 5){
                        let minLev = Math.min(...levels);
                        if(level > minLev) canUpgrade = false;
                    }
                    if(!canUpgrade){
                        showMsg(`Нельзя: все улицы группы должны быть застроены равномерно (разница не более 1 дома)`, true);
                        modal.remove();
                        return;
                    }
                    players[currentPlayer].money -= cost;
                    cell.improvements = level + 1;
                    showMsg(`${cell.name} улучшен до уровня ${cell.improvements} (аренда вырастет!)`);
                    updateUI();
                    modal.remove();
                    if(players[currentPlayer].money<0) checkBankrupt(currentPlayer);
                } else {
                    showMsg("Недостаточно денег или уже отель", true);
                }
            };
        });
        modal.querySelectorAll(".downgrade-act").forEach(btn => {
            btn.onclick = () => {
                let propId = parseInt(btn.dataset.id);
                let cell = BOARD_DATA[propId];
                let level = cell.improvements || 0;
                let sellPrice = level===5 ? cell.houseCost : Math.floor(cell.houseCost/2);
                if(level > 0){
                    cell.improvements = level - 1;
                    players[currentPlayer].money += sellPrice;
                    showMsg(`Проданы улучшения на ${cell.name}, получено ${sellPrice}₽`);
                    updateUI();
                    modal.remove();
                } else {
                    showMsg("Нет улучшений для продажи", true);
                }
            };
        });
        modal.querySelector("#closeUpgradeModal").onclick = () => modal.remove();
    }

    // ---------- Обработка хода, аукционы, налоги и прочее ----------
    async function processLand(playerIdx, cellId, stepSum) {
        const cell = BOARD_DATA[cellId];
        const p = players[playerIdx];
        if(cell.type === "start") return false;
        if(cell.type === "tax") {
            p.money -= cell.rent;
            showMsg(`${p.name} заплатил налог ${cell.rent}₽`);
            if(p.money<0) checkBankrupt(playerIdx);
            return false;
        }
        if(cell.type === "jail") return false;
        if(cell.type === "chest") { chestAction(playerIdx); return false; }
        if(cell.type === "chance") { chanceAction(playerIdx); return false; }
        if(cell.type === "property" || cell.type==="railroad" || cell.type==="utility"){
            let owner = cellOwner[cell.id];
            if(owner === -1){
                if(p.money >= cell.price){
                    let buy = confirm(`${p.name}, купить ${cell.name} за ${cell.price}₽?`);
                    if(buy){
                        p.money -= cell.price;
                        cellOwner[cell.id] = playerIdx;
                        p.properties.push(cell.id);
                        showMsg(`${p.name} купил ${cell.name}`);
                        updateUI();
                        return false;
                    } else {
                        showMsg(`${p.name} отказался. Аукцион!`);
                        startAuction(cell.id, cell.price);
                        return true;
                    }
                } else {
                    showMsg(`Не хватает денег. Аукцион!`);
                    startAuction(cell.id, cell.price);
                    return true;
                }
            } else if(owner !== playerIdx) {
                let rent = getRent(cell, playerIdx);
                if(rent>0){
                    p.money -= rent;
                    players[owner].money += rent;
                    showMsg(`${p.name} платит аренду ${rent}₽ ${players[owner].name} за ${cell.name}`);
                    updateUI();
                    if(p.money<0) checkBankrupt(playerIdx);
                }
            }
        }
        return false;
    }

    function startAuction(cellId, startPrice){
        if(!gameActive) return;
        waitingAuction = true;
        let currentBid = startPrice;
        let currentBidder = -1;
        let nextBidderIdx = (currentPlayer === 0) ? 1 : 0;
        function nextTurn(){
            if(!waitingAuction) return;
            let playerId = nextBidderIdx % 2;
            nextBidderIdx++;
            showModalAuction(cellId, currentBid, currentBidder, playerId, (newBid, skip)=>{
                if(skip){
                    if(currentBidder === -1) endAuction(null);
                    else endAuction(currentBidder, currentBid);
                    return;
                }
                if(newBid !== undefined && newBid > currentBid){
                    if(players[playerId].money >= newBid){
                        currentBid = newBid;
                        currentBidder = playerId;
                        showMsg(`${players[playerId].name} поднимает ставку до ${newBid}₽`);
                        nextTurn();
                    } else {
                        showMsg(`Недостаточно денег. Пропуск.`);
                        nextTurn();
                    }
                } else {
                    showMsg(`${players[playerId].name} пропускает ставку.`);
                    nextTurn();
                }
            });
        }
        nextTurn();
    }

    function showModalAuction(cellId, currentBid, currentBidder, activePlayerId, callback){
        const modalDiv = document.createElement("div");
        modalDiv.className = "modal";
        const cell = BOARD_DATA[cellId];
        modalDiv.innerHTML = `
            <div class="modal-card">
                <h3>🏆 АУКЦИОН: ${cell.name}</h3>
                <p>Текущая ставка: <strong style="color:#0ff">${currentBid}₽</strong> ${currentBidder!==-1 ? `(игрок ${players[currentBidder].icon})` : "—"}</p>
                <p>💰 Ваши деньги: ${players[activePlayerId].money}₽</p>
                <input type="number" id="bidAmount" class="bid-input" value="${currentBid+10}" min="${currentBid+5}" step="5">
                <div class="modal-buttons">
                    <button id="bidBtn" class="btn-neon">💰 ПОВЫСИТЬ</button>
                    <button id="skipBtn" class="btn-neon">⏭️ ПРОПУСК</button>
                </div>
            </div>
        `;
        document.body.appendChild(modalDiv);
        const bidInput = modalDiv.querySelector("#bidAmount");
        const bidBtn = modalDiv.querySelector("#bidBtn");
        const skipBtn = modalDiv.querySelector("#skipBtn");
        const cleanup = ()=> modalDiv.remove();
        bidBtn.onclick = ()=>{
            let newVal = parseInt(bidInput.value);
            if(isNaN(newVal)) newVal = currentBid+10;
            if(newVal > currentBid && newVal <= players[activePlayerId].money){
                cleanup();
                callback(newVal, false);
            } else {
                alert(`Ставка должна быть выше ${currentBid} и в пределах ваших денег (${players[activePlayerId].money})`);
            }
        };
        skipBtn.onclick = ()=>{
            cleanup();
            callback(undefined, true);
        };
    }

    function endAuction(winnerId, finalPrice){
        waitingAuction = false;
        if(winnerId !== null && finalPrice !== undefined){
            let cellId = window._tempAuctionCell;
            if(cellId !== undefined && BOARD_DATA[cellId]){
                players[winnerId].money -= finalPrice;
                cellOwner[cellId] = winnerId;
                players[winnerId].properties.push(cellId);
                showMsg(`Игрок ${players[winnerId].name} выиграл аукцион за ${finalPrice}₽ и получает ${BOARD_DATA[cellId].name}!`);
                updateUI();
                if(players[winnerId].money<0) checkBankrupt(winnerId);
            }
        } else {
            showMsg("Аукцион без победителя, клетка свободна.");
        }
        window._tempAuctionCell = null;
    }

    function chestAction(pIdx){
        let events = [{text:"+200",val:200},{text:"+100",val:100},{text:"-150",val:-150},{text:"+300",val:300},{text:"-50",val:-50},{text:"старт+200",move:0,add:200}];
        let e = events[Math.floor(Math.random()*events.length)];
        let p = players[pIdx];
        if(e.val){ p.money += e.val; showMsg(`Общ. казна: ${e.text} ₽. Баланс: ${p.money}`);}
        if(e.move!==undefined){
            let old = p.pos;
            p.pos = e.move;
            if(old > p.pos) p.money+=200;
            p.money += e.add||0;
            showMsg(`Перемещение на СТАРТ +200₽`);
        }
        updateUI(); if(p.money<0) checkBankrupt(pIdx);
    }
    function chanceAction(pIdx){
        let events = [{text:"старт+200",move:0,add:200},{text:"тюрьма",jail:true},{text:"-100",val:-100},{text:"+50",val:50},{text:"на Сент-Чарльз 11",move:11},{text:"+150",val:150}];
        let e = events[Math.floor(Math.random()*events.length)];
        let p = players[pIdx];
        if(e.val){ p.money += e.val; showMsg(`Шанс: ${e.text} → ${e.val}₽`);}
        if(e.move!==undefined){
            let old = p.pos; p.pos = e.move;
            if(old > p.pos && e.move!==0) p.money+=200;
            if(e.add) p.money+=e.add;
            showMsg(`Шанс: перемещение на ${BOARD_DATA[p.pos].name}`);
        }
        if(e.jail){ p.inJail=true; p.pos=10; p.jailTurns=0; showMsg(`Тюрьма!`);}
        updateUI(); if(p.money<0) checkBankrupt(pIdx);
    }
    function checkBankrupt(idx){ if(players[idx].money<0){ players[idx].money=0; gameActive=false; showMsg(`${players[idx].name} банкрот! Победил ${players[1-idx].name} 🎉`,true); } }

    async function rollAction(){
        if(!gameActive) return;
        if(waitingAuction){ showMsg("Идёт аукцион!",true); return; }
        if(justRolled){ showMsg("Завершите ход!",true); return; }
        let p = players[currentPlayer];
        if(p.inJail){
            let choice = confirm(`В тюрьме. Заплатить 50₽ и выйти? (Отмена - бросок дубля)`);
            if(choice && p.money>=50){ p.money-=50; p.inJail=false; showMsg("Выход за 50₽"); updateUI();}
            else{
                let d1=Math.floor(Math.random()*6)+1, d2=Math.floor(Math.random()*6)+1;
                dice1Val=d1; dice2Val=d2; diceSum=d1+d2;
                updateUI();
                if(d1===d2){ p.inJail=false; showMsg(`Дубль! Выход, ход на ${diceSum}`); await moveAndLand(currentPlayer,diceSum); justRolled=true; if(d1===d2){ justRolled=false; rollAction();} }
                else{ p.jailTurns++; showMsg(`Не дубль (${p.jailTurns}/3)`); if(p.jailTurns>=3 && p.money>=50){ p.money-=50; p.inJail=false; showMsg("Принудительный выход");} justRolled=true;}
                updateUI(); if(!gameActive) return;
                return;
            }
        }
        let d1=Math.floor(Math.random()*6)+1, d2=Math.floor(Math.random()*6)+1;
        dice1Val=d1; dice2Val=d2; diceSum=d1+d2;
        updateUI();
        animateDice();
        showMsg(`${p.name} выбросил ${d1}+${d2}=${diceSum}`);
        await moveAndLand(currentPlayer, diceSum);
        justRolled = true;
        if(d1===d2){
            doublesCount++;
            if(doublesCount===3){ goToJail(currentPlayer); doublesCount=0; justRolled=true; }
            else{ showMsg(`ДУБЛЬ! Доп. ход!`); justRolled=false; rollAction(); }
        } else doublesCount=0;
    }

    async function moveAndLand(pid, steps){
        let p = players[pid];
        let oldPos = p.pos;
        let newPos = (oldPos + steps) % BOARD_DATA.length;
        if(newPos < oldPos){ p.money+=200; showMsg(`Проход старта +200₽`);}
        p.pos = newPos;
        updateUI();
        let auctionBlock = await processLand(pid, newPos, steps);
        if(auctionBlock) waitingAuction=true;
        updateUI();
        if(players[pid].money<0) checkBankrupt(pid);
    }
    function goToJail(pid){ players[pid].inJail=true; players[pid].pos=10; players[pid].jailTurns=0; showMsg(`${players[pid].name} в тюрьме!`); updateUI(); }
    function endTurn(){
        if(!gameActive) return;
        if(!justRolled && !waitingAuction){ showMsg("Сначала бросьте кубики!",true); return; }
        if(waitingAuction){ showMsg("Аукцион не завершён!",true); return; }
        justRolled=false; waitingAuction=false;
        currentPlayer = currentPlayer===0?1:0;
        showMsg(`Ход переходит к ${players[currentPlayer].name}. Бросайте!`);
        updateUI();
    }
    function openTradeModal(){
        if(!gameActive) return;
        let p0=players[0], p1=players[1];
        let props0 = p0.properties.map(pid=>BOARD_DATA[pid].name).join(", ") || "нет";
        let props1 = p1.properties.map(pid=>BOARD_DATA[pid].name).join(", ") || "нет";
        let modal = document.createElement("div"); modal.className = "modal";
        modal.innerHTML = `
            <div class="modal-card" style="max-width:500px">
                <h3>🤝 ПРЕДЛОЖИТЬ СДЕЛКУ</h3>
                <div style="display:flex; gap:20px; margin:20px 0"><div><strong>🔴 ${p0.name}</strong><br>💰 ${p0.money}<br>🏠 ${props0}</div><div><strong>🔵 ${p1.name}</strong><br>💰 ${p1.money}<br>🏠 ${props1}</div></div>
                <input id="tradeMoney" type="number" placeholder="Сумма перевода (от 1 к 2, если отриц. то от 2 к 1)" style="margin:6px;padding:8px;border-radius:30px">
                <input id="tradePropsFrom0" placeholder="ID участков от Игрока1 (через пробел)" style="margin:6px;padding:8px;border-radius:30px">
                <input id="tradePropsFrom1" placeholder="ID участков от Игрока2 (через пробел)" style="margin:6px;padding:8px;border-radius:30px">
                <div class="modal-buttons"><button id="doTradeBtn" class="btn-neon">✅ ОТПРАВИТЬ</button><button id="cancelTradeBtn" class="btn-neon">❌ ОТМЕНА</button></div>
            </div>
        `;
        document.body.appendChild(modal);
        const doBtn = modal.querySelector("#doTradeBtn");
        const cancel = modal.querySelector("#cancelTradeBtn");
        doBtn.onclick = ()=>{
            let moneyVal = parseInt(modal.querySelector("#tradeMoney").value) || 0;
            let props0list = modal.querySelector("#tradePropsFrom0").value.split(" ").map(Number).filter(v=>!isNaN(v) && players[0].properties.includes(v));
            let props1list = modal.querySelector("#tradePropsFrom1").value.split(" ").map(Number).filter(v=>!isNaN(v) && players[1].properties.includes(v));
            if(moneyVal>=0 && players[0].money >= moneyVal){ players[0].money-=moneyVal; players[1].money+=moneyVal; }
            else if(moneyVal<0 && players[1].money >= -moneyVal){ players[1].money-=-moneyVal; players[0].money+=-moneyVal; }
            for(let pid of props0list){ if(cellOwner[pid]===0){ cellOwner[pid]=1; players[0].properties=players[0].properties.filter(p=>p!==pid); players[1].properties.push(pid); } }
            for(let pid of props1list){ if(cellOwner[pid]===1){ cellOwner[pid]=0; players[1].properties=players[1].properties.filter(p=>p!==pid); players[0].properties.push(pid); } }
            updateUI(); showMsg("Сделка выполнена!"); modal.remove();
        };
        cancel.onclick = ()=>modal.remove();
    }
    function animateDice(){
        let d1el = document.getElementById("dice1"), d2el = document.getElementById("dice2");
        d1el.classList.add("roll-anim"); d2el.classList.add("roll-anim");
        setTimeout(()=>{ d1el.classList.remove("roll-anim"); d2el.classList.remove("roll-anim"); },300);
    }
    function resetGame(){
        players = [
            { id:0, name:"Игрок 1", money:1500, pos:0, inJail:false, jailTurns:0, properties:[], icon:"🔴" },
            { id:1, name:"Игрок 2", money:1500, pos:0, inJail:false, jailTurns:0, properties:[], icon:"🔵" }
        ];
        BOARD_DATA.forEach(cell => { if(cell.type==="property") cell.improvements = 0; });
        cellOwner.fill(-1);
        currentPlayer=0; gameActive=true; justRolled=false; waitingAuction=false; doublesCount=0;
        dice1Val=1; dice2Val=1;
        updateUI();
        showMsg("Новая игра! Ход Игрока 1.");
    }
    document.getElementById("rollBtn").onclick = rollAction;
    document.getElementById("endTurnBtn").onclick = endTurn;
    document.getElementById("resetBtn").onclick = resetGame;
    document.getElementById("tradeBtn").onclick = openTradeModal;
    document.getElementById("upgradeBtn").onclick = openUpgradePanel;
    resetGame();
</script>
</body>
</html>
